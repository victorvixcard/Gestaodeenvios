APP_NAME="VIXCard Gestão de Pedidos"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vixcard_gestaodeenvios
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# WhatsApp (Z-API ou Evolution API)
WHATSAPP_PROVIDER=zapi
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Prazo padrão em dias úteis
ORDER_DEADLINE_BUSINESS_DAYS=7

# Cidade para feriados
HOLIDAY_STATE=ES
HOLIDAY_CITY=Serra
